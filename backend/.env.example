# Required: use ONE of these
OPENAI_API_KEY=sk-...
# OR for OpenRouter (unified API for many models)
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional (defaults shown)
OPENAI_MODEL=gpt-4o
# OPENROUTER_MODEL=openai/gpt-4o
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
# Disable PDF upload/OCR/index building in deployed retrieval-only mode
# ENABLE_ADMIN_RAG=0
# Optional: set absolute path if Tesseract is not on PATH (Windows example)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Number of top chunks to retrieve per request
RAG_TOP_K=6
# Chunking
CHUNK_SIZE_CHARS=1400
CHUNK_OVERLAP_CHARS=200
# OCR resolution multiplier (2.0 is a good tradeoff; increase if OCR is messy)
OCR_ZOOM=2.0
